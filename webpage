        <span>Me &#9662;</span>
      </div>
    </div>
  </div>
</nav>

<!-- Main Content -->
<div class="container">

  <!-- Left Sidebar -->
  <div class="left-sidebar">
    <div class="card profile-card">
      <div class="cover"></div>
      <div class="avatar-wrapper"><div class="avatar">SW</div></div>
