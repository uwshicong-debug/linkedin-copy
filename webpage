<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LinkedIn Clone</title>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: -apple-system, system-ui, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  background: #f4f2ee;
  color: #191919;
  line-height: 1.5;
}

a { text-decoration: none; color: inherit; }

/* ── Navbar ── */
nav {
  background: #fff;
  border-bottom: 1px solid #e0e0e0;
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-inner {
  max-width: 1128px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 8px;
  height: 52px;
}

.nav-left {
  display: flex;
  align-items: center;
  gap: 8px;
}

.logo {
  width: 34px;
  height: 34px;
  background: #0a66c2;
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-weight: 700;
  font-size: 20px;
}

.search-box {
  display: flex;
  align-items: center;
  background: #eef3f8;
  border-radius: 4px;
  padding: 0 8px;
  height: 34px;
  width: 280px;
}

.search-box svg { width: 16px; height: 16px; fill: #666; flex-shrink: 0; }

.search-box input {
  border: none;
  background: none;
  outline: none;
  padding: 4px 8px;
  font-size: 14px;
  width: 100%;
  color: #191919;
}

.nav-right {
  display: flex;
  align-items: center;
  gap: 4px;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 4px 12px;
  cursor: pointer;
  border-radius: 4px;
  position: relative;
  min-width: 60px;
}

.nav-item:hover { background: #f0f0f0; }

.nav-item.active { border-bottom: 2px solid #191919; }

.nav-item svg { width: 24px; height: 24px; fill: #666; }
.nav-item.active svg { fill: #191919; }

.nav-item span {
  font-size: 12px;
  color: #666;
  margin-top: 2px;
  white-space: nowrap;
}

.nav-item.active span { color: #191919; }

.nav-badge {
  position: absolute;
  top: 0;
  right: 10px;
  background: #cc1016;
  color: #fff;
  font-size: 10px;
  font-weight: 600;
  border-radius: 10px;
  padding: 0 6px;
  min-width: 16px;
  height: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-divider {
  width: 1px;
  height: 40px;
  background: #e0e0e0;
  margin: 0 4px;
}

.nav-avatar {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background: linear-gradient(135deg, #0a66c2, #004182);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 11px;
  font-weight: 600;
}

/* ── Layout ── */
.container {
  max-width: 1128px;
  margin: 0 auto;
  padding: 24px 8px;
  display: grid;
  grid-template-columns: 225px 1fr 300px;
  gap: 24px;
}

/* ── Cards ── */
.card {
  background: #fff;
  border-radius: 8px;
  border: 1px solid #e0e0e0;
  overflow: hidden;
}

/* ── Left Sidebar ── */
.profile-card .cover {
  height: 56px;
  background: linear-gradient(135deg, #004182, #0a66c2, #378fe9);
}

.profile-card .avatar-wrapper {
  display: flex;
  justify-content: center;
  margin-top: -38px;
  position: relative;
}

.avatar {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  border: 3px solid #fff;
  background: linear-gradient(135deg, #0a66c2, #004182);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28px;
  font-weight: 600;
}

.profile-card .info {
  text-align: center;
  padding: 12px 16px;
}

.profile-card .name {
  font-size: 16px;
  font-weight: 600;
}

.profile-card .headline {
  font-size: 12px;
  color: #666;
  margin-top: 4px;
}

.profile-stats {
  border-top: 1px solid #e0e0e0;
  padding: 12px 16px;
}

.profile-stat {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 4px 0;
  cursor: pointer;
}

.profile-stat:hover { background: #f0f0f0; margin: 0 -16px; padding: 4px 16px; }

.profile-stat .label { font-size: 12px; color: #666; }
.profile-stat .count { font-size: 12px; color: #0a66c2; font-weight: 600; }

.sidebar-links {
  padding: 12px 0;
}

.sidebar-link {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 16px;
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
}

.sidebar-link:hover { background: #f0f0f0; }

.sidebar-link svg { width: 16px; height: 16px; fill: #666; }

/* ── Feed ── */
.create-post {
  padding: 16px;
  display: flex;
  gap: 12px;
  align-items: flex-start;
}

.create-post .avatar-sm {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: linear-gradient(135deg, #0a66c2, #004182);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 18px;
  font-weight: 600;
  flex-shrink: 0;
}

.create-post .input-box {
  flex: 1;
  border: 1px solid #c0c0c0;
  border-radius: 35px;
  padding: 12px 16px;
  font-size: 14px;
  color: #666;
  cursor: pointer;
}

.create-post .input-box:hover { background: #f0f0f0; }

.create-actions {
  display: flex;
  justify-content: space-around;
  padding: 4px 16px 12px;
}

.create-action {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 12px;
  border-radius: 4px;
  cursor: pointer;
  font-size: 14px;
  font-weight: 600;
  color: #666;
}

.create-action:hover { background: #f0f0f0; }

.create-action .icon {
  width: 20px;
  height: 20px;
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
}

.icon-media { background: #378fe9; color: #fff; }
.icon-event { background: #c37d16; color: #fff; }
.icon-article { background: #e06847; color: #fff; }

.feed-sort {
  display: flex;
  align-items: center;
  padding: 8px 16px;
  border-top: 1px solid #e0e0e0;
  gap: 8px;
}

.feed-sort .line { flex: 1; height: 1px; background: #e0e0e0; }
.feed-sort span { font-size: 12px; color: #666; white-space: nowrap; }
.feed-sort select {
  border: none;
  background: none;
  font-size: 12px;
  font-weight: 600;
  color: #191919;
  cursor: pointer;
  outline: none;
}

/* ── Post ── */
.post { margin-top: 8px; }

.post-header {
  display: flex;
  align-items: flex-start;
  padding: 12px 16px;
  gap: 8px;
}

.post-avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-weight: 600;
  font-size: 18px;
}

.post-meta { flex: 1; }
.post-name { font-size: 14px; font-weight: 600; }
.post-name:hover { color: #0a66c2; cursor: pointer; text-decoration: underline; }
.post-desc { font-size: 12px; color: #666; }
.post-time { font-size: 12px; color: #999; }

.post-header .more {
  cursor: pointer;
  padding: 4px;
  border-radius: 50%;
  font-size: 18px;
  color: #666;
}

.post-header .more:hover { background: #f0f0f0; }

.post-body {
  padding: 0 16px 12px;
  font-size: 14px;
  line-height: 1.6;
}

.post-body .see-more {
  color: #666;
  cursor: pointer;
  font-weight: 600;
}

.post-body .see-more:hover { color: #0a66c2; }

.post-image {
  width: 100%;
  aspect-ratio: 16/9;
  object-fit: cover;
  display: block;
}

.post-img-placeholder {
  width: 100%;
  aspect-ratio: 16/9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48px;
}

.post-engagement {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 16px;
  font-size: 12px;
  color: #666;
}

.post-reactions {
  display: flex;
  align-items: center;
  gap: 2px;
}

.reaction-icons {
  display: flex;
}

.reaction-icon {
  width: 18px;
  height: 18px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 10px;
  margin-right: -4px;
  border: 2px solid #fff;
}

.post-engagement a:hover { text-decoration: underline; color: #0a66c2; cursor: pointer; }

.post-actions {
  display: flex;
  justify-content: space-around;
  border-top: 1px solid #e0e0e0;
  padding: 4px 8px;
}

.post-action {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 10px 8px;
  border-radius: 4px;
  cursor: pointer;
  font-size: 14px;
  font-weight: 600;
  color: #666;
  flex: 1;
  justify-content: center;
}

.post-action:hover { background: #f0f0f0; }
.post-action.liked { color: #0a66c2; }
.post-action svg { width: 20px; height: 20px; fill: currentColor; }

/* ── Right Sidebar ── */
.news-card { padding: 12px 16px; }

.news-card h3 {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 8px;
}

.news-item {
  padding: 8px 0;
  cursor: pointer;
}

.news-item:hover .news-title { color: #0a66c2; }

.news-title {
  font-size: 13px;
  font-weight: 600;
  line-height: 1.3;
}

.news-meta {
  font-size: 12px;
  color: #999;
  margin-top: 2px;
}

.news-bullet {
  display: inline-block;
  width: 4px;
  height: 4px;
  background: #191919;
  border-radius: 50%;
  margin-right: 8px;
  vertical-align: middle;
}

.show-more {
  font-size: 14px;
  font-weight: 600;
  color: #666;
  cursor: pointer;
  padding: 8px 0;
  display: flex;
  align-items: center;
  gap: 4px;
}

.show-more:hover { color: #0a66c2; }

.ad-card {
  margin-top: 8px;
  padding: 16px;
  text-align: center;
}

.ad-card .ad-label {
  font-size: 10px;
  color: #999;
  text-align: right;
  margin-bottom: 8px;
}

.ad-card .ad-text {
  font-size: 14px;
  color: #666;
  margin-bottom: 12px;
}

.ad-card .ad-img {
  width: 120px;
  height: 120px;
  border-radius: 50%;
  background: linear-gradient(135deg, #f0c27f, #4b1248);
  margin: 0 auto 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36px;
}

.ad-card .ad-cta {
  display: inline-block;
  padding: 8px 24px;
  border: 1px solid #0a66c2;
  border-radius: 20px;
  color: #0a66c2;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
}

.ad-card .ad-cta:hover { background: #e8f0fe; }

.follow-card { margin-top: 8px; padding: 12px 16px; }
.follow-card h3 { font-size: 16px; font-weight: 600; margin-bottom: 8px; }

.follow-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 0;
}

.follow-avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-weight: 600;
  font-size: 16px;
  flex-shrink: 0;
}

.follow-info { flex: 1; }
.follow-name { font-size: 14px; font-weight: 600; }
.follow-desc { font-size: 12px; color: #666; }

.follow-btn {
  padding: 6px 16px;
  border: 1px solid #666;
  border-radius: 20px;
  font-size: 14px;
  font-weight: 600;
  color: #666;
  cursor: pointer;
  background: none;
  white-space: nowrap;
}

.follow-btn:hover { background: #f0f0f0; border-color: #191919; color: #191919; }

.footer-links {
  margin-top: 16px;
  display: flex;
  flex-wrap: wrap;
  gap: 4px 12px;
  justify-content: center;
  padding: 0 16px;
}

.footer-links a {
  font-size: 11px;
  color: #999;
}

.footer-links a:hover { color: #0a66c2; text-decoration: underline; }

.footer-copy {
  text-align: center;
  font-size: 11px;
  color: #999;
  margin-top: 8px;
  padding-bottom: 16px;
}

/* ── Modal ── */
.modal-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.6);
  z-index: 200;
  align-items: center;
  justify-content: center;
}

.modal-overlay.active { display: flex; }

.modal {
  background: #fff;
  border-radius: 12px;
  width: 552px;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 24px;
  border-bottom: 1px solid #e0e0e0;
}

.modal-header h2 { font-size: 18px; }

.modal-close {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  border: none;
  background: none;
  font-size: 24px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #666;
}

.modal-close:hover { background: #f0f0f0; }

.modal-body {
  padding: 16px 24px;
  flex: 1;
  overflow-y: auto;
}

.modal-body .post-author {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 12px;
}

.modal-body textarea {
  width: 100%;
  border: none;
  outline: none;
  resize: none;
  font-size: 16px;
  min-height: 120px;
  font-family: inherit;
  color: #191919;
}

.modal-body textarea::placeholder { color: #999; }

.modal-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 24px;
  border-top: 1px solid #e0e0e0;
}

.modal-tools {
  display: flex;
  gap: 4px;
}

.modal-tool {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  border: none;
  background: none;
  cursor: pointer;
  font-size: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-tool:hover { background: #f0f0f0; }

.btn-post {
  padding: 8px 20px;
  border-radius: 20px;
  border: none;
  background: #0a66c2;
  color: #fff;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
}

.btn-post:hover { background: #004182; }
.btn-post:disabled { background: #ccc; cursor: default; }

/* ── Responsive ── */
@media (max-width: 900px) {
  .container { grid-template-columns: 1fr; }
  .left-sidebar, .right-sidebar { display: none; }
  .search-box { width: 180px; }
}
</style>
</head>
